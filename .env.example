# Stargaze.io Environment Variables
# Copy this file to .env and fill in your values

# NASA API Key (get free at https://api.nasa.gov)
# Without this, NASA APOD uses DEMO_KEY (rate limited)
VITE_NASA_API_KEY=DEMO_KEY

# Firebase (optional — only needed for community features)
# Get these from your Firebase Console → Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
