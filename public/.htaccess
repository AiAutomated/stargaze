# ─── Stargaze.io SPA Routing Fix ─────────────────────────────────────────────
# Supports Apache mod_rewrite AND LiteSpeed (Hostinger's web server).
# All URLs that are not real files/directories fall through to index.html,
# allowing React Router to handle client-side navigation.

Options -MultiViews -Indexes

# ── Apache / LiteSpeed mod_rewrite ──────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical host: redirect www → non-www (301)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Serve prerendered static pages: /shower/perseids → shower/perseids.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Skip rewrite for existing files (CSS, JS, images, fonts, etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Everything else → index.html (React Router takes over)
  RewriteRule ^ index.html [L]
</IfModule>

# ── Fallback: ErrorDocument (works even when mod_rewrite is off) ─────────────
# When a 404 occurs, serve index.html so the React SPA still loads.
ErrorDocument 404 /index.html

# ── MIME types (prevents 404 on .wasm, .glb used by Cesium) ─────────────────
<IfModule mod_mime.c>
  AddType application/wasm          .wasm
  AddType model/gltf-binary         .glb
  AddType application/octet-stream  .czml
</IfModule>

# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Long-term caching for hashed build assets ────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 0 seconds"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType image/png                "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
</IfModule>
